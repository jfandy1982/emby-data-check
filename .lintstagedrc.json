{
  "**/*.*": ["secretlint \"**/*\" --maskSecrets --secretlintrc .github/linters/.secretlintrc.json", "pretty-quick --staged"],
  "{apps,libs}/**/*.{ts,js,html,json,scss,css,md}": "nx affected:lint --uncommitted --fix true",
  "{apps,libs}/**/*.{scss,css}": "nx affected:stylelint --uncommitted --fix true",
  "**/package.json": "npmPkgJsonLint --configFile .github/linters/.npmpackagejsonlintrc.json .",
  "*.{ts,js,html,json,scss,css,md,yaml,yml}": "nx format:write --base=main --head=HEAD"
}
