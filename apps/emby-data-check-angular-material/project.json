{
  "name": "emby-data-check-angular-material",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "edc",
  "sourceRoot": "apps/emby-data-check-angular-material/src",
  "tags": ["scope:ui"],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/emby-data-check-angular-material",
        "index": "apps/emby-data-check-angular-material/src/index.html",
        "main": "apps/emby-data-check-angular-material/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/emby-data-check-angular-material/tsconfig.app.json",
        "assets": ["apps/emby-data-check-angular-material/src/favicon.ico", "apps/emby-data-check-angular-material/src/assets"],
        "styles": [
          "./node_modules/bootstrap/dist/css/bootstrap-reboot.min.css",
          "./node_modules/bootstrap/dist/css/bootstrap-grid.min.css",
          "./node_modules/@angular/material/prebuilt-themes/indigo-pink.css",
          "apps/emby-data-check-angular-material/src/styles.css"
        ],
        "scripts": []
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kb",
              "maximumError": "4kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "browserTarget": "emby-data-check-angular-material:build:production"
        },
        "development": {
          "browserTarget": "emby-data-check-angular-material:build:development"
        }
      },
      "defaultConfiguration": "development",
      "options": {
        "proxyConfig": "apps/emby-data-check-angular-material/proxy.conf.json"
      }
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "browserTarget": "emby-data-check-angular-material:build"
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/emby-data-check-angular-material/**/*.ts", "apps/emby-data-check-angular-material/**/*.html"]
      }
    },
    "stack": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "cd docker && docker compose down && docker compose --env-file ../.env up",
            "description": "Spin up the DB docker container"
          },
          {
            "command": "nx serve emby-data-check-api",
            "description": "Start the Emby Data Check API",
            "forwardAllArgs": false
          },
          {
            "command": "nx serve emby-data-check-angular-material",
            "description": "Start the Emby Data Check UI (Angular Material)"
          }
        ]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/emby-data-check-angular-material/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "serve-static": {
      "executor": "@nrwl/web:file-server",
      "options": {
        "buildTarget": "emby-data-check-angular-material:build"
      }
    }
  }
}
