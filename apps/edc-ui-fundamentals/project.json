{
  "name": "edc-ui-fundamentals",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "edc-fundamentals",
  "sourceRoot": "apps/edc-ui-fundamentals/src",
  "tags": ["type:app", "scope:ui", "ui:fundamentals"],
  "targets": {
    "build": {
      "configurations": {
        "development": {
          "fileReplacements": [
            {
              "replace": "libs/shared/util-env/src/lib/environment.ts",
              "with": "libs/shared/util-env/src/lib/environment.development.ts"
            }
          ],
          "namedChunks": true,
          "outputHashing": "none",
          "optimization": false,
          "sourceMap": {
            "hidden": true,
            "scripts": true,
            "styles": true
          },
          "vendorChunk": true
        },
        "test": {
          "fileReplacements": [
            {
              "replace": "libs/shared/util-env/src/lib/environment.ts",
              "with": "libs/shared/util-env/src/lib/environment.test.ts"
            }
          ]
        },
        "production": {
          "fileReplacements": [
            {
              "replace": "libs/shared/util-env/src/lib/environment.ts",
              "with": "libs/shared/util-env/src/lib/environment.production.ts"
            }
          ]
        }
      },
      "executor": "@angular-devkit/build-angular:browser",
      "defaultConfiguration": "production",
      "options": {
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/edc-ui-fundamentals/src/assets/",
            "output": "assets/"
          },
          {
            "glob": "favicon.ico",
            "input": "src/",
            "output": "/"
          }
        ],
        "buildOptimizer": true,
        "extractLicenses": true,
        "index": "apps/edc-ui-fundamentals/src/index.html",
        "inlineStyleLanguage": "scss",
        "main": "apps/edc-ui-fundamentals/src/main.ts",
        "namedChunks": false,
        "outputHashing": "all",
        "outputPath": "dist/apps/edc-ui-fundamentals",
        "polyfills": ["zone.js"],
        "styles": [
          "apps/edc-ui-fundamentals/src/styles.scss",
          "./node_modules/@sap-theming/theming-base-content/content/Base/baseLib/sap_horizon/css_variables.css",
          "./node_modules/fundamental-styles/dist/theming/sap_horizon.css",
          "./node_modules/fundamental-styles/dist/fonts/sap_horizon_fonts.css",
          "./node_modules/fundamental-styles/dist/fundamental-styles.css"
        ],
        "stylePreprocessorOptions": {
          "includePaths": ["libs/client/ui-style-fundamentals/src/lib/scss"]
        },
        "sourceMap": false,
        "scripts": [],
        "tsConfig": "apps/edc-ui-fundamentals/tsconfig.app.json",
        "optimization": true,
        "vendorChunk": false
      },
      "outputs": ["{options.outputPath}"]
    },
    "serve": {
      "configurations": {
        "development": {
          "browserTarget": "edc-ui-fundamentals:build:development"
        },
        "test": {
          "browserTarget": "edc-ui-fundamentals:build:test"
        },
        "production": {
          "browserTarget": "edc-ui-fundamentals:build:production"
        }
      },
      "defaultConfiguration": "production",
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "browserTarget": "edc-ui-fundamentals:build",
        "port": 4201,
        "proxyConfig": "apps/edc-ui-fundamentals/proxy.conf.json"
      }
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "browserTarget": "edc-ui-fundamentals:build"
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/edc-ui-fundamentals/**/*.ts", "apps/edc-ui-fundamentals/**/*.html"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/edc-ui-fundamentals/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "edc-ui-fundamentals:build",
        "port": 4201
      }
    },
    "docker-build": {
      "dependsOn": ["build"],
      "command": "docker build -f apps/edc-ui-fundamentals/Dockerfile . -t edc-ui-fundamentals"
    },
    "stack": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "docker compose down && docker compose --env-file .env up",
            "description": "Spin up the DB docker container"
          },
          {
            "command": "wait-on tcp:5432 && nx serve edc-api",
            "description": "Start the Emby Data Check API",
            "forwardAllArgs": false
          },
          {
            "command": "wait-on tcp:3000 && nx serve edc-ui-fundamentals",
            "description": "Start the Emby Data Check UI (Fundamentals Library)"
          }
        ],
        "parallel": true
      }
    }
  }
}
