{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "implicitDependencies": ["edc-ui-ng"],
  "name": "edc-ui-ng-cypress-e2e",
  "projectType": "application",
  "sourceRoot": "apps/edc-ui-ng-cypress-e2e/src",
  "tags": ["type:e2e", "ui:angular"],
  "targets": {
    "e2e": {
      "configurations": {
        "coverage": {
          "devServerTarget": "edc-ui-ng:serve:coverage"
        }
      },
      "executor": "@nx/cypress:cypress",
      "metadata": {
        "description": "Local: headless, dev-server on port 4200 (no build required)"
      },
      "options": {
        "cypressConfig": "apps/edc-ui-ng-cypress-e2e/cypress.config.ts",
        "devServerTarget": "edc-ui-ng:serve:development",
        "testingType": "e2e"
      },
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"]
    },
    "e2e-ci": {
      "configurations": {
        "e2e-cypress-coverage": {
          "devServerTarget": "edc-ui-ng:serve-static:e2e-cypress-coverage"
        }
      },
      "dependsOn": ["edc-ui-ng:build"],
      "executor": "@nx/cypress:cypress",
      "metadata": {
        "description": "CI/Pipeline: headless, Chrome, serve-static on port 4201 with coverage (requires build)"
      },
      "options": {
        "browser": "chrome",
        "cypressConfig": "apps/edc-ui-ng-cypress-e2e/cypress.config.ts",
        "devServerTarget": "edc-ui-ng:serve-static",
        "testingType": "e2e"
      },
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"]
    },
    "open-cypress": {
      "executor": "@nx/cypress:cypress",
      "metadata": {
        "description": "Local: interactive Cypress GUI, dev-server on port 4200"
      },
      "options": {
        "cypressConfig": "apps/edc-ui-ng-cypress-e2e/cypress.config.ts",
        "devServerTarget": "edc-ui-ng:serve:development",
        "testingType": "e2e",
        "watch": true
      }
    }
  }
}
