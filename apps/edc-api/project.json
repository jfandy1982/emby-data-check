{
  "name": "edc-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/edc-api/src",
  "projectType": "application",
  "tags": ["type:app", "scope:api"],
  "targets": {
    "build": {
      "configurations": {
        "development": {
          "fileReplacements": [
            { "replace": "libs/shared/util-env/src/lib/environment.ts", "with": "libs/shared/util-env/src/lib/environment.development.ts" }
          ]
        },
        "test": {
          "fileReplacements": [
            { "replace": "libs/shared/util-env/src/lib/environment.ts", "with": "libs/shared/util-env/src/lib/environment.test.ts" }
          ]
        },
        "production": {
          "fileReplacements": [
            { "replace": "libs/shared/util-env/src/lib/environment.ts", "with": "libs/shared/util-env/src/lib/environment.production.ts" }
          ]
        }
      },
      "defaultConfiguration": "production",
      "executor": "@nx/webpack:webpack",
      "options": {
        "assets": ["apps/edc-api/src/assets"],
        "compiler": "tsc",
        "extractLicenses": true,
        "isolatedConfig": true,
        "main": "apps/edc-api/src/main.ts",
        "optimization": false,
        "outputPath": "dist/apps/edc-api",
        "target": "node",
        "tsConfig": "apps/edc-api/tsconfig.app.json",
        "webpackConfig": "apps/edc-api/webpack.config.js"
      },
      "outputs": ["{options.outputPath}"]
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "edc-api:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "edc-api:build:development"
        },
        "test": {
          "buildTarget": "edc-api:build:test"
        },
        "production": {
          "buildTarget": "edc-api:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/edc-api/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/edc-api/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "docker-build": {
      "dependsOn": ["build"],
      "command": "docker build -f apps/edc-api/Dockerfile . -t edc-api"
    },
    "stack": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "docker compose down && docker compose --env-file .env up",
            "description": "Spin up the DB docker container"
          },
          {
            "command": "wait-on tcp:5432 && nx serve edc-api",
            "description": "Start the Emby Data Check API",
            "forwardAllArgs": false
          }
        ],
        "parallel": true
      }
    }
  }
}
