{
  "name": "emby-data-check-api-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "targets": {
    "e2e": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/emby-data-check-api-e2e/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/emby-data-check-api-e2e/**/*.{js,ts}"]
      }
    }
  },
  "tags": ["scope:e2e"],
  "implicitDependencies": ["emby-data-check-api"]
}
