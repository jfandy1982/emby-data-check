{
  "name": "fundamentals-ui-edc2",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "edc",
  "sourceRoot": "apps/fundamentals-ui-edc2/src",
  "tags": ["scope:ui"],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/fundamentals-ui-edc2",
        "index": "apps/fundamentals-ui-edc2/src/index.html",
        "main": "apps/fundamentals-ui-edc2/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/fundamentals-ui-edc2/tsconfig.app.json",
        "assets": ["apps/fundamentals-ui-edc2/src/favicon.ico", "apps/fundamentals-ui-edc2/src/assets"],
        "styles": [
          "./node_modules/fundamental-styles/dist/icon.css",
          "./node_modules/fundamental-styles/dist/theming/sap_horizon.css",
          "./node_modules/fundamental-styles/dist/fonts/sap_horizon_fonts.css",
          "./node_modules/fundamental-styles/dist/fundamental-styles.css",
          "apps/fundamentals-ui-edc2/src/styles.scss"
        ],
        "scripts": []
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "2mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kb",
              "maximumError": "4kb"
            }
          ],
          "outputHashing": "all"
        },
        "test": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kb",
              "maximumError": "4kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "cypress": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "nx serve edc-ui-fundamentals --port=5002 --configuration=test",
            "forwardAllArgs": false
          },
          {
            "command": "wait-on http://localhost:5002 && echo 'READY'"
          }
        ],
        "parallel": true,
        "readyWhen": "READY"
      }
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "browserTarget": "fundamentals-ui-edc2:build:production"
        },
        "development": {
          "browserTarget": "fundamentals-ui-edc2:build:development"
        }
      },
      "defaultConfiguration": "development",
      "options": {
        "proxyConfig": "apps/fundamentals-ui-edc2/proxy.conf.json"
      }
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "browserTarget": "fundamentals-ui-edc2:build"
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/fundamentals-ui-edc2/**/*.ts", "apps/fundamentals-ui-edc2/**/*.html"]
      }
    },
    "stack": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "cd docker && docker compose down && docker compose --env-file ../.env up",
            "description": "Spin up the DB docker container"
          },
          {
            "command": "wait-on tcp:5432 && nx serve edc-api",
            "description": "Start the Emby Data Check API",
            "forwardAllArgs": false
          },
          {
            "command": "wait-on tcp:3000 && nx serve edc-ui-fundamentals",
            "description": "Start the Emby Data Check UI (Fundamentals-Ngx)"
          }
        ],
        "parallel": true
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/fundamentals-ui-edc2/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "serve-static": {
      "executor": "@nrwl/web:file-server",
      "options": {
        "buildTarget": "fundamentals-ui-edc2:build"
      }
    }
  }
}
