{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "implicitDependencies": ["edc-api"],
  "name": "edc-api-e2e",
  "projectType": "application",
  "tags": ["type:e2e"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "metadata": {
        "description": "Local: headless, requires API running on port $API_PORT (default: 3000)"
      },
      "options": {
        "jestConfig": "apps/edc-api-e2e/jest.config.ts"
      },
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"]
    }
  }
}
