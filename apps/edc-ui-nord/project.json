{
  "name": "edc-ui-nord",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "edc-nord",
  "sourceRoot": "apps/edc-ui-nord/src",
  "tags": ["type:app", "scope:ui", "ui:nord"],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/edc-ui-nord",
        "index": "apps/edc-ui-nord/src/index.html",
        "main": "apps/edc-ui-nord/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/edc-ui-nord/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/edc-ui-nord/src/assets/",
            "output": "assets/"
          },
          {
            "glob": "favicon.ico",
            "input": "src/",
            "output": "/"
          }
        ],
        "styles": ["apps/edc-ui-nord/src/styles.scss"],
        "stylePreprocessorOptions": {
          "includePaths": ["libs/client/ui-style-nord/src/lib/scss"]
        },
        "sourceMap": {
          "hidden": true,
          "scripts": true,
          "styles": true
        },
        "scripts": []
      },
      "configurations": {
        "production": {
          "outputHashing": "all"
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "port": 4202,
        "proxyConfig": "apps/edc-ui-nord/proxy.conf.json"
      },
      "configurations": {
        "production": {
          "browserTarget": "edc-ui-nord:build:production"
        },
        "development": {
          "browserTarget": "edc-ui-nord:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "browserTarget": "edc-ui-nord:build"
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/edc-ui-nord/**/*.ts", "apps/edc-ui-nord/**/*.html"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/edc-ui-nord/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "edc-ui-nord:build",
        "port": 4202
      }
    },
    "docker-build": {
      "dependsOn": ["build"],
      "command": "docker build -f apps/edc-ui-nord/Dockerfile . -t edc-ui-nord"
    }
  }
}
