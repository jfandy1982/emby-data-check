{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "lib": ["es2020", "dom"],
    "module": "esnext",
    "moduleResolution": "node",
    "paths": {
      "@edc/shared/environment": ["libs/shared/environment/src/index.ts"],
      "@edc/shared/model/api": ["libs/shared/model/api/src/index.ts"],
      "@edc/shared/model/db": ["libs/shared/model/db/src/index.ts"],
      "@edc/shared/model/emby": ["libs/shared/model/emby/src/index.ts"],
      "@edc/shared/model/enum": ["libs/shared/model/enum/src/index.ts"],
      "@edc/shared/model/interface": ["libs/shared/model/interface/src/index.ts"],
      "@edc/shared/model/pagination": ["libs/shared/model/pagination/src/index.ts"],
      "@edc/shared/model/types": ["libs/shared/model/types/src/index.ts"],
      "@edc/test/cucumber": ["libs/test-util/cucumber/src/index.ts"],
      "@edc/test/defaults": ["libs/test-util/defaults/src/index.ts"],
      "@edc/test/fake-factory": ["libs/test-util/fake-factory/src/index.ts"]
    },
    "rootDir": ".",
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2015"
  },
  "exclude": ["node_modules", "tmp"]
}
