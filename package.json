{
  "name": "emby-data-check",
  "version": "0.0.1-SNAPSHOT",
  "description": "An (opinionated) Emby Data Check Tool",
  "keywords": [
    "emby"
  ],
  "license": "MIT",
  "engines": {
    "node": "20.9.0",
    "npm": "10.1.0"
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jfandy1982/emby-data-check.git"
  },
  "author": "Andreas Ziegler (dev@andreasziegler.net)",
  "bugs": {
    "url": "https://github.com/jfandy1982/emby-data-check/issues"
  },
  "homepage": "https://jfandy1982.github.io/emby-data-check/",
  "scripts": {
    "checks:affected": "nx affected --parallel --targets lint stylelint build test",
    "checks:all:conf:ci": "nx run-many --parallel --targets=lint,stylelint,build,test,stylelint --configuration=ci",
    "checks:all:conf:default": "nx run-many --parallel --targets=lint,stylelint,build,test,stylelint",
    "checks:all:conf:dev": "nx run-many --parallel --targets=lint,stylelint,build,test,stylelint --configuration=development",
    "checks:all:conf:prod": "nx run-many --parallel --targets=lint,stylelint,build,test,stylelint --configuration=production",
    "checks:all:conf:test": "nx run-many --parallel --targets=lint,stylelint,build,test,stylelint --configuration=test",
    "cleanup:all": "npm run cleanup:generated && npm run cleanup:deps && npm install",
    "cleanup:cache:angular": "rimraf ./.angular",
    "cleanup:cache:nx": "rimraf ./.nx",
    "cleanup:deps": "rimraf ./package-lock.json && rimraf ./node_modules",
    "cleanup:generated": "npm run cleanup:cache:angular && npm run cleanup:cache:nx && rimraf ./coverage && rimraf ./dist",
    "e2e:affected": "nx affected:e2e --parallel",
    "e2e:all": "nx run-many --target=e2e --parallel",
    "format:check": "nx format:check --all",
    "format:write": "nx format:write --all",
    "lint:check:megalinter": "npx mega-linter-runner --flavor javascript",
    "ng": "nx",
    "nx": "nx",
    "prepare": "husky install",
    "spell:check": "cspell lint --dot --show-suggestions --no-progress --config ./.cspell.json",
    "spell:search:dict": "cspell trace --all --config ./.cspell.json",
    "stack:api": "nx run edc-api:stack",
    "stack:ng": "nx run edc-ui-ng:stack",
    "stack:ngx": "nx run edc-ui-fundamentals:stack",
    "stack:nord": "nx run edc-ui-nord:stack",
    "typeorm": "ts-node -P tsconfig.orm.json ./node_modules/typeorm/cli",
    "typeorm:config": "npm run typeorm -- -d ./apps/edc-api/db/migrations.config.ts",
    "typeorm:migration:create": "npm run typeorm -- migration:create ./apps/edc-api/db/migrations/$npm_config_name",
    "typeorm:migration:generate": "npm run typeorm -- migration:generate -d ./apps/edc-api/db/migrations.config.ts ./apps/edc-api/db/migrations/$npm_config_name",
    "typeorm:migration:revert": "npm run typeorm:config -- migration:revert",
    "typeorm:migration:run": "npm run typeorm:config -- migration:run",
    "typeorm:migration:show": "npm run typeorm:config -- migration:show",
    "upgrade": "nx migrate latest --interactive",
    "upgrade:doit": "npm install && nx migrate --run-migrations"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "dependencies": {
    "@angular/animations": "^17.0.0",
    "@angular/cdk": "^17.0.0",
    "@angular/common": "^17.0.0",
    "@angular/compiler": "^17.0.0",
    "@angular/core": "^17.0.0",
    "@angular/forms": "^17.0.0",
    "@angular/material": "^17.0.0",
    "@angular/platform-browser": "^17.0.0",
    "@angular/platform-browser-dynamic": "^17.0.0",
    "@angular/router": "^17.0.0",
    "@fundamental-ngx/cdk": "^0.47.0",
    "@fundamental-ngx/core": "^0.47.0",
    "@fundamental-ngx/i18n": "^0.47.0",
    "@fundamental-ngx/platform": "^0.47.0",
    "@nestjs/axios": "^3.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/terminus": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nx/angular": "17.1.3",
    "@sap-theming/theming-base-content": "^11.0.0",
    "axios": "^1.0.0",
    "bootstrap": "^5.0.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "fundamental-styles": "^0.32.0",
    "lodash": "^4.0.0",
    "lodash-es": "^4.0.0",
    "nord": "^0.2.0",
    "normalize.css": "^8.0.0",
    "pg": "^8.0.0",
    "reflect-metadata": "^0.1.0",
    "rxjs": "^7.0.0",
    "slugify": "^1.0.0",
    "tslib": "^2.0.0",
    "typeorm": "^0.3.0",
    "zone.js": "^0.14.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.0.0",
    "@angular-devkit/core": "^17.0.0",
    "@angular-devkit/schematics": "^17.0.0",
    "@angular-eslint/eslint-plugin": "^17.0.0",
    "@angular-eslint/eslint-plugin-template": "^17.0.0",
    "@angular-eslint/template-parser": "^17.0.0",
    "@angular/cli": "^17.0.0",
    "@angular/compiler-cli": "^17.0.0",
    "@angular/language-service": "^17.0.0",
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "@commitlint/config-nx-scopes": "^18.0.0",
    "@commitlint/cz-commitlint": "^18.0.0",
    "@cspell/dict-de-de": "^3.0.0",
    "@eslint/eslintrc": "^2.0.0",
    "@eslint/js": "^8.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@nx/cypress": "17.1.3",
    "@nx/eslint": "17.1.3",
    "@nx/eslint-plugin": "17.1.3",
    "@nx/jest": "17.1.3",
    "@nx/js": "17.1.3",
    "@nx/nest": "17.1.3",
    "@nx/node": "17.1.3",
    "@nx/storybook": "17.1.3",
    "@nx/web": "17.1.3",
    "@nx/webpack": "17.1.3",
    "@nx/workspace": "17.1.3",
    "@schematics/angular": "^17.0.0",
    "@secretlint/secretlint-rule-preset-recommend": "^7.0.0",
    "@swc-node/register": "^1.0.0",
    "@swc/core": "^1.0.0",
    "@types/jest": "^29.0.0",
    "@types/lodash": "^4.0.0",
    "@types/lodash-es": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "babel-jest": "^29.0.0",
    "commitizen": "^4.0.0",
    "cspell": "^8.0.0",
    "cypress": "^13.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-cypress": "^2.0.0",
    "husky": "^8.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "jest-environment-node": "^29.0.0",
    "jest-preset-angular": "^13.0.0",
    "lint-staged": "^15.0.0",
    "npm-package-json-lint": "^7.0.0",
    "nx": "17.1.3",
    "nx-stylelint": "^17.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "secretlint": "^8.0.0",
    "stylelint": "^15.0.0",
    "stylelint-config-standard": "^34.0.0",
    "stylelint-config-standard-scss": "^11.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "typescript": "5.2.2",
    "wait-on": "^7.0.0"
  }
}
