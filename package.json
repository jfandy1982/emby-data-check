    "@typescript-eslint/parser": "^6.0.0",
    "browser-sync": "^3.0.0",
    "cspell": "^8.0.0",
    "cypress": "^13.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-cypress": "^2.0.0",
    "husky": "^9.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "jest-preset-angular": "^14.0.0",
    "jsonc-eslint-parser": "^2.0.0",
    "lint-staged": "^15.0.0",
