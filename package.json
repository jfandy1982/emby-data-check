    "class-validator": "^0.14.0",
    "lodash": "^4.0.0",
    "nord": "^0.2.0",
    "normalize.css": "^8.0.0",
    "pg": "^8.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "slugify": "^1.0.0",
    "typeorm": "^0.3.0",
    "zone.js": "^0.15.0"
  }
}
