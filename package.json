{
  "name": "emby-data-check",
  "version": "0.0.1-SNAPSHOT",
  "description": "An (opinionated) Emby Data Check Tool",
  "keywords": [
    "emby"
  ],
  "license": "MIT",
  "engines": {
    "node": "18.17.0",
    "npm": "9.8.1"
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jfandy1982/emby-data-check.git"
  },
  "author": "Andreas Ziegler (dev@andreasziegler.net)",
  "bugs": {
    "url": "https://github.com/jfandy1982/emby-data-check/issues"
  },
  "homepage": "https://jfandy1982.github.io/emby-data-check/",
  "scripts": {
    "build:affected": "nx affected:build --configuration=production",
    "build:all": "nx run-many --target=build --all",
    "cleanup:all": "npm-run-all --continue-on-error --parallel \"cleanup:!(all)\" && npm install",
    "cleanup:deps": "rimraf ./package-lock.json && rimraf ./node_modules",
    "cleanup:generated": "rimraf ./dist && rimraf ./angular",
    "e2e:affected": "nx affected:e2e --parallel",
    "e2e:all": "nx run-many --target=e2e --parallel --all",
    "lint:affected": "nx affected:lint --parallel",
    "lint:all": "nx run-many --target=lint --all",
    "lint:check:megalinter": "npx mega-linter-runner --flavor javascript",
    "ng": "nx",
    "nx": "nx",
    "prepare": "husky install",
    "pretty-quick": "pretty-quick",
    "test:affected": "nx affected:test --parallel",
    "test:all": "nx run-many --target=test --parallel --all",
    "upgrade": "nx migrate latest --interactive"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "dependencies": {
    "@angular/animations": "^16.0.0",
    "@angular/cdk": "^16.0.0",
    "@angular/common": "^16.0.0",
    "@angular/compiler": "^16.0.0",
    "@angular/core": "^16.0.0",
    "@angular/forms": "^16.0.0",
    "@angular/material": "^16.0.0",
    "@angular/platform-browser": "^16.0.0",
    "@angular/platform-browser-dynamic": "^16.0.0",
    "@angular/router": "^16.0.0",
    "@fundamental-ngx/cdk": "^0.44.0",
    "@fundamental-ngx/core": "^0.44.0",
    "@fundamental-ngx/i18n": "^0.44.0",
    "@fundamental-ngx/platform": "^0.44.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nx/angular": "16.6.0",
    "@sap-theming/theming-base-content": "^11.0.0",
    "axios": "^1.0.0",
    "bootstrap": "^5.0.0",
    "fundamental-styles": "^0.30.0",
    "lodash-es": "^4.0.0",
    "nord": "^0.2.0",
    "normalize.css": "^8.0.0",
    "reflect-metadata": "^0.1.0",
    "rxjs": "^7.0.0",
    "tslib": "^2.0.0",
    "zone.js": "^0.13.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^16.0.0",
    "@angular-devkit/core": "^16.0.0",
    "@angular-devkit/schematics": "^16.0.0",
    "@angular-eslint/eslint-plugin": "^16.0.0",
    "@angular-eslint/eslint-plugin-template": "^16.0.0",
    "@angular-eslint/template-parser": "^16.0.0",
    "@angular/cli": "^16.0.0",
    "@angular/compiler-cli": "^16.0.0",
    "@angular/language-service": "^16.0.0",
    "@commitlint/cli": "^17.0.0",
    "@commitlint/config-conventional": "^17.0.0",
    "@commitlint/config-nx-scopes": "^17.0.0",
    "@commitlint/cz-commitlint": "^17.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@nx/cypress": "16.6.0",
    "@nx/eslint-plugin": "16.6.0",
    "@nx/jest": "16.6.0",
    "@nx/js": "16.6.0",
    "@nx/linter": "16.6.0",
    "@nx/nest": "16.6.0",
    "@nx/node": "16.6.0",
    "@nx/web": "16.6.0",
    "@nx/webpack": "16.6.0",
    "@nx/workspace": "16.6.0",
    "@schematics/angular": "^16.0.0",
    "@secretlint/secretlint-rule-preset-recommend": "^7.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "commitizen": "^4.0.0",
    "cypress": "^12.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.0.0",
    "eslint-plugin-cypress": "^2.0.0",
    "husky": "^8.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "jest-environment-node": "^29.0.0",
    "jest-preset-angular": "^13.0.0",
    "lint-staged": "^13.0.0",
    "npm-package-json-lint": "^7.0.0",
    "npm-run-all": "^4.0.0",
    "nx": "16.6.0",
    "nx-cloud": "16.3.0",
    "nx-stylelint": "^15.0.0",
    "prettier": "^2.0.0",
    "pretty-quick": "^3.0.0",
    "rimraf": "^5.0.0",
    "secretlint": "^7.0.0",
    "stylelint": "^15.0.0",
    "stylelint-config-standard": "^34.0.0",
    "stylelint-config-standard-scss": "^10.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0",
    "wait-on": "^7.0.0"
  }
}
