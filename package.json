{
  "name": "emby-data-check",
  "version": "0.0.1-SNAPSHOT",
  "description": "An (opinionated) Emby Data Check Tool",
  "license": "MIT",
  "engines": {
    "node": "18.14.0"
  },
  "scripts": {
    "build:affected": "nx affected:build --configuration=production",
    "build:all": "nx run-many --target=build --all",
    "cleanup": "npm-run-all --continue-on-error --parallel \"cleanup:*\" && npm install",
    "cleanup:api": "rimraf ./dist",
    "cleanup:deps": "rimraf ./node_modules",
    "cleanup:package": "rimraf ./package-lock.json",
    "cleanup:qa": "rimraf ./coverage",
    "cleanup:ui": "rimraf ./.angular",
    "e2e:affected": "nx affected:e2e --parallel --skip-nx-cache",
    "e2e:all": "nx run-many --target=e2e --parallel --skip-nx-cache --all",
    "format:check:all": "npx prettier --check --ignore-unknown \"**/*\"",
    "format:fix:affected": "npx pretty-quick --staged",
    "format:fix:all": "npx prettier --write --ignore-unknown \"**/*\"",
    "lint:affected": "nx affected:lint --parallel --skip-nx-cache",
    "lint:all": "nx run-many --target=lint --all",
    "lint:check:megalinter": "npx mega-linter-runner --flavor javascript",
    "lint:check:npmPkgJsonLint": "npmPkgJsonLint --configFile .github/linters/.npmpackagejsonlintrc.json .",
    "lint:check:secretlint": "secretlint \"**/*\" --maskSecrets --secretlintrc .github/linters/.secretlintrc.json",
    "ng": "nx",
    "pre-commit": "lint-staged",
    "prepare": "husky install",
    "qa:affected": "npm-run-all --continue-on-error \"lint:affected\" \"test:affected\" \"e2e:affected\"",
    "qa:all": "npm-run-all --continue-on-error \"format:check:all\" \"lint:all\" \"lint:check:megalinter\" \"lint:check:npmPkgJsonLint\" \"lint:check:secretlint\" \"test:all\" \"e2e:all\"",
    "start:api:dev": "nx serve emby-data-check-api --configuration development",
    "start:ui:dev": "nx serve emby-data-check-angular-material --configuration development",
    "test:affected": "nx affected:test --parallel --skip-nx-cache",
    "test:all": "nx run-many --target=test --parallel --skip-nx-cache --all",
    "upgrade": "nx migrate latest"
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jfandy1982/emby-data-check.git"
  },
  "author": "Andreas Ziegler (dev@andreasziegler.net)",
  "bugs": {
    "url": "https://github.com/jfandy1982/emby-data-check/issues"
  },
  "homepage": "https://jfandy1982.github.io/emby-data-check/",
  "lint-staged": {
    "**/*.*": [
      "npm run lint:check:secretlint",
      "npm run format:fix:affected"
    ],
    "**/package.json": [
      "npm run lint:check:npmPkgJsonLint"
    ]
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^15.0.0",
    "@angular-eslint/eslint-plugin": "^15.0.0",
    "@angular-eslint/eslint-plugin-template": "^15.0.0",
    "@angular-eslint/template-parser": "^15.0.0",
    "@angular/cli": "^15.0.0",
    "@angular/compiler-cli": "^15.0.0",
    "@angular/language-service": "^15.0.0",
    "@nestjs/schematics": "^9.0.0",
    "@nestjs/testing": "^9.0.0",
    "@nrwl/angular": "15.7.0",
    "@nrwl/cli": "15.7.0",
    "@nrwl/cypress": "15.7.0",
    "@nrwl/eslint-plugin-nx": "15.7.0",
    "@nrwl/jest": "15.7.0",
    "@nrwl/linter": "15.7.0",
    "@nrwl/nest": "15.7.0",
    "@nrwl/node": "15.7.0",
    "@nrwl/webpack": "15.7.0",
    "@nrwl/workspace": "15.7.0",
    "@secretlint/secretlint-rule-preset-recommend": "^6.0.0",
    "@types/jest": "^28.0.0",
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "cypress": "^12.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.0.0",
    "eslint-plugin-cypress": "^2.0.0",
    "husky": "^8.0.0",
    "jest": "^28.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "jest-preset-angular": "^12.0.0",
    "lint-staged": "^13.0.0",
    "npm-package-json-lint": "^6.0.0",
    "npm-run-all": "^4.0.0",
    "nx": "15.7.0",
    "prettier": "^2.0.0",
    "pretty-quick": "^3.0.0",
    "rimraf": "^4.0.0",
    "secretlint": "^6.0.0",
    "ts-jest": "^28.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^4.0.0"
  },
  "dependencies": {
    "@angular/animations": "^15.0.0",
    "@angular/cdk": "^15.0.0",
    "@angular/common": "^15.0.0",
    "@angular/compiler": "^15.0.0",
    "@angular/core": "^15.0.0",
    "@angular/forms": "^15.0.0",
    "@angular/material": "^15.0.0",
    "@angular/platform-browser": "^15.0.0",
    "@angular/platform-browser-dynamic": "^15.0.0",
    "@angular/router": "^15.0.0",
    "@nestjs/axios": "^2.0.0",
    "@nestjs/common": "^9.0.0",
    "@nestjs/config": "^2.0.0",
    "@nestjs/core": "^9.0.0",
    "@nestjs/platform-express": "^9.0.0",
    "@nestjs/swagger": "^6.0.0",
    "@nestjs/typeorm": "^9.0.0",
    "axios": "^1.0.0",
    "bootstrap": "^5.0.0",
    "pg": "^8.0.0",
    "reflect-metadata": "^0.1.0",
    "rxjs": "^7.0.0",
    "tslib": "^2.0.0",
    "typeorm": "^0.3.0",
    "zone.js": "^0.12.0"
  }
}
