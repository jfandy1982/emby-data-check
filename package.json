{
  "name": "emby-data-check",
  "version": "0.0.1-SNAPSHOT",
  "description": "An (opinionated) Emby Data Check Tool",
  "keywords": [
    "emby"
  ],
  "license": "MIT",
  "engines": {
    "node": "18.15.0"
  },
  "scripts": {
    "build:affected": "nx affected:build --configuration=production",
    "build:all": "nx run-many --target=build --all",
    "cleanup:all": "npm-run-all --continue-on-error --parallel \"cleanup:!(all)\" && npm install",
    "cleanup:api": "rimraf ./dist",
    "cleanup:deps": "rimraf ./node_modules",
    "cleanup:package": "rimraf ./package-lock.json",
    "cleanup:qa": "rimraf ./coverage",
    "cleanup:ui": "rimraf ./.angular",
    "docker:api": "docker build -t edc-api -f ./docker/Dockerfile.prod.edc-api --no-cache .",
    "docker:ui:ng": "docker build -t edc-ui-ng -f ./docker/Dockerfile.prod.edc-ui-ng --no-cache .",
    "docker:ui:ngx": "docker build -t edc-ui-ngx -f ./docker/Dockerfile.prod.edc-ui-fundamentals --no-cache .",
    "e2e:affected": "nx affected:e2e --parallel --skip-nx-cache",
    "e2e:all": "nx run-many --target=e2e --parallel --skip-nx-cache --all",
    "format:check:all": "npx prettier --check --ignore-unknown \"**/*\"",
    "format:fix:affected": "npx pretty-quick --staged",
    "format:fix:all": "npx prettier --write --ignore-unknown \"**/*\"",
    "lint:affected": "nx affected:lint --parallel --skip-nx-cache",
    "lint:all": "nx run-many --target=lint --all",
    "lint:check:megalinter": "npx mega-linter-runner --flavor javascript",
    "lint:check:npmPkgJsonLint": "npmPkgJsonLint --configFile .github/linters/.npmpackagejsonlintrc.json .",
    "lint:check:secretlint": "secretlint \"**/*\" --maskSecrets --secretlintrc .github/linters/.secretlintrc.json",
    "ng": "nx",
    "pre-commit": "lint-staged",
    "prepare": "husky install",
    "qa:affected": "npm-run-all --continue-on-error \"lint:affected\" \"test:affected\" \"e2e:affected\"",
    "qa:all": "npm-run-all --continue-on-error \"format:check:all\" \"lint:all\" \"lint:check:megalinter\" \"lint:check:npmPkgJsonLint\" \"lint:check:secretlint\" \"test:all\" \"e2e:all\"",
    "start:api:dev": "nx serve edc-api --configuration development",
    "start:stack:ng": "nx run edc-ui-ng:stack",
    "start:stack:ngx": "nx run edc-ui-fundamentals:stack",
    "start:ui:ng:dev": "nx serve edc-ui-ng --configuration development",
    "start:ui:ngx:dev": "nx serve edc-ui-fundamentals --configuration development",
    "test:affected": "nx affected:test --parallel --skip-nx-cache",
    "test:all": "nx run-many --target=test --parallel --skip-nx-cache --all",
    "upgrade": "nx migrate latest --interactive"
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jfandy1982/emby-data-check.git"
  },
  "author": "Andreas Ziegler (dev@andreasziegler.net)",
  "bugs": {
    "url": "https://github.com/jfandy1982/emby-data-check/issues"
  },
  "homepage": "https://jfandy1982.github.io/emby-data-check/",
  "lint-staged": {
    "**/*.*": [
      "npm run lint:check:secretlint",
      "npm run format:fix:affected"
    ],
    "**/package.json": [
      "npm run lint:check:npmPkgJsonLint"
    ]
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "15.2.6",
    "@angular-devkit/core": "15.2.6",
    "@angular-devkit/schematics": "15.2.6",
    "@angular-eslint/eslint-plugin": "15.2.1",
    "@angular-eslint/eslint-plugin-template": "15.2.1",
    "@angular-eslint/template-parser": "15.2.1",
    "@angular/cli": "15.2.6",
    "@angular/compiler-cli": "15.2.8",
    "@angular/language-service": "15.2.8",
    "@nestjs/schematics": "9.1.0",
    "@nestjs/testing": "9.4.0",
    "@nrwl/cli": "15.9.2",
    "@nrwl/cypress": "15.9.2",
    "@nrwl/eslint-plugin-nx": "15.9.2",
    "@nrwl/jest": "15.9.2",
    "@nrwl/js": "15.9.2",
    "@nrwl/linter": "15.9.2",
    "@nrwl/nest": "15.9.2",
    "@nrwl/node": "15.9.2",
    "@nrwl/web": "15.9.2",
    "@nrwl/webpack": "15.9.2",
    "@nrwl/workspace": "15.9.2",
    "@schematics/angular": "15.2.6",
    "@secretlint/secretlint-rule-preset-recommend": "6.2.3",
    "@types/jest": "29.5.1",
    "@types/node": "18.15.13",
    "@types/uuid": "9.0.1",
    "@typescript-eslint/eslint-plugin": "5.59.0",
    "@typescript-eslint/parser": "5.59.0",
    "cypress": "12.10.0",
    "eslint": "8.38.0",
    "eslint-config-prettier": "8.8.0",
    "eslint-plugin-cypress": "2.13.2",
    "husky": "8.0.3",
    "jest": "29.5.0",
    "jest-environment-jsdom": "29.5.0",
    "jest-environment-node": "29.5.0",
    "jest-preset-angular": "13.0.1",
    "lint-staged": "13.2.1",
    "npm-package-json-lint": "6.4.0",
    "npm-run-all": "4.1.5",
    "nx": "15.9.2",
    "prettier": "2.8.8",
    "pretty-quick": "3.1.3",
    "rimraf": "5.0.0",
    "secretlint": "6.2.3",
    "ts-jest": "29.1.0",
    "ts-node": "10.9.1",
    "typescript": "4.9.5",
    "wait-on": "7.0.1"
  },
  "dependencies": {
    "@angular/animations": "15.2.8",
    "@angular/cdk": "15.2.8",
    "@angular/common": "15.2.8",
    "@angular/compiler": "15.2.8",
    "@angular/core": "15.2.8",
    "@angular/forms": "15.2.8",
    "@angular/material": "15.2.8",
    "@angular/platform-browser": "15.2.8",
    "@angular/platform-browser-dynamic": "15.2.8",
    "@angular/router": "15.2.8",
    "@fundamental-ngx/core": "0.40.1",
    "@fundamental-ngx/platform": "0.40.1",
    "@nestjs/axios": "2.0.0",
    "@nestjs/common": "9.4.0",
    "@nestjs/config": "2.3.1",
    "@nestjs/core": "9.4.0",
    "@nestjs/platform-express": "9.4.0",
    "@nestjs/swagger": "6.3.0",
    "@nestjs/typeorm": "9.0.1",
    "@nrwl/angular": "15.9.2",
    "@sap-theming/theming-base-content": "11.3.2",
    "axios": "1.3.6",
    "bootstrap": "5.2.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.0",
    "lodash-es": "4.17.21",
    "pg": "8.10.0",
    "reflect-metadata": "0.1.13",
    "rxjs": "7.8.0",
    "slugify": "1.6.6",
    "tslib": "2.5.0",
    "typeorm": "0.3.15",
    "zone.js": "0.13.0"
  }
}
